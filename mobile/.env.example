# ArkenEdu Mobile App — Environment Config
# Copy this file to .env and fill in the correct value for your environment.
#
# LOCAL DEV (Expo Go on same machine):
#   EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api
#
# LOCAL DEV (physical device on same network):
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:8000/api
#
# PRODUCTION (EAS production build):
#   EXPO_PUBLIC_API_BASE_URL=https://api.arkenedu.com/api
#   (production values are also pinned in eas.json -> build.production.env,
#    which take precedence over this file during EAS builds)
#
# IMPORTANT: The EXPO_PUBLIC_ prefix is required — Expo only inlines env vars
# with this prefix into the client bundle. Variables without it are invisible
# to the app at runtime.

EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Parent web portal — used by the Fees screen's "Open UPI Payment Portal"
# CTA. Should NOT include a trailing slash; /parent/fee-pay is appended.
#   Local dev: http://localhost:5173
#   Production: https://www.arkenedu.com
EXPO_PUBLIC_WEB_PORTAL_URL=http://localhost:5173
