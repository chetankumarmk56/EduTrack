{
  "cli": {
    "version": ">= 18.13.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.arkenedu.com/api",
        "EXPO_PUBLIC_WEB_PORTAL_URL": "https://www.arkenedu.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.arkenedu.com/api",
        "EXPO_PUBLIC_WEB_PORTAL_URL": "https://www.arkenedu.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
