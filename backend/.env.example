# EduTrack Backend Configuration

# General Application Settings
APP_NAME="EduTrack SaaS"
VERSION="1.0.0"
API_V1_STR="/api"
ENVIRONMENT="dev"  # dev, prod, test
PORT=8000

# Database configuration (PostgreSQL)
# For local dev: postgresql://luffy@localhost/school
"postgresql://user:password@host:port/dbname"

# Security & JWT
# Important: Override SECRET_KEY with a strong, 32-byte secret for production
SECRET_KEY="edutrack-secret-key-32-bytes"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI Configuration (Optional)
# Obtain from Google AI Studio (Gemini)
GOOGLE_API_KEY="YOUR_GOOGLE_AI_API_KEY"

# Frontend Integration
FRONTEND_URL="http://localhost:3000"
