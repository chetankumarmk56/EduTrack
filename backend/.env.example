# ArkenEdu Backend Configuration

# General Application Settings
APP_NAME="ArkenEdu"
VERSION="1.0.0"
API_V1_STR="/api"
ENVIRONMENT="dev"  # dev, prod, test

# Seeding — demo school dataset
# In dev/test the full demo dataset is always seeded.
# In prod only the superadmin is seeded unless this flag is set to true.
# Set to true ONLY when you explicitly want demo data in production.
SEED_DEMO_DATA=false
PORT=8000

# Database configuration (PostgreSQL)
# For local dev: postgresql://luffy@localhost/school
DATABASE_URL="postgresql://user:password@host:port/dbname"

# ⚠️ SECURITY: SECRET_KEY is REQUIRED
# Generate a new secret key with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# MUST be at least 32 characters
SECRET_KEY="<GENERATE NEW KEY - Required for production>"

# JWT & Token Configuration
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security & CORS
FRONTEND_URL="http://localhost:5173"
# Comma-separated EXTRA browser origins allowed to call the API (in addition
# to FRONTEND_URL). Native mobile builds are NOT subject to CORS, but the Expo
# *web* preview (localhost:8081 / :19006) is — so when you want to test the
# mobile app in a browser against this backend, add those origins here:
#   ADDITIONAL_CORS_ORIGINS="http://localhost:8081,http://localhost:19006"
# In dev (ENVIRONMENT!=prod) localhost origins are already allowed automatically;
# you only need this on a prod backend you want to hit from a local browser.
ADDITIONAL_CORS_ORIGINS=""
COOKIE_DOMAIN=""  # Set to your domain in production (yourdomain.com)
# Auth cookie SameSite policy. Leave empty for auto (none in prod, lax in dev).
# Set to "lax" when the SPA and API share one registrable domain — e.g.
# www.arkenedu.com + api.arkenedu.com (same-site) — for stronger CSRF defense.
# Use "none" only when the frontend is on a DIFFERENT site than the API.
COOKIE_SAMESITE=""

# AI Configuration
# Question Bank + Lesson Plan generation now run IN-PROCESS inside the
# backend/AI package — no external microservice is required. See
# backend/AI/README.md for the full picture (and the microservice-ready seam).

# Obtain from Google AI Studio (Gemini) — optional, not used by the in-process flow.
GOOGLE_API_KEY="YOUR_GOOGLE_AI_API_KEY"

# OpenAI — required for AI generation.
# SIMPLEST SETUP (recommended): set ONE key in OPENAI_API_KEY and leave the two
# per-tool keys empty. Both the Question Bank and Lesson Plan generators fall
# back to OPENAI_API_KEY, so a single shared key powers both.
#  • OPENAI_API_KEY            — shared key for BOTH generators (+ legacy inline QB).
#  • QUESTION_BANK_OPENAI_API_KEY / LESSON_PLAN_OPENAI_API_KEY — OPTIONAL per-tool
#    overrides. Only set these if QB and LP must use different keys.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4o-mini"
QUESTION_BANK_OPENAI_API_KEY=""
LESSON_PLAN_OPENAI_API_KEY=""

# Models for the in-process generators. QB sends the PDF to the OpenAI
# Responses API; LP sends extracted chapter text to Chat Completions.
# Must be REAL OpenAI model IDs — "gpt-5.5" does not exist and will 502.
QUESTION_BANK_OPENAI_MODEL="gpt-4o"
LESSON_PLAN_OPENAI_MODEL="gpt-4o"

# Per-request timeout (seconds) for the IN-PROCESS OpenAI calls. Lesson Plan
# produces a full class-by-class plan, so its single completion is much
# larger/slower than Question Bank's — hence the larger default. Keep BELOW
# your gateway read timeouts (gunicorn `timeout`, nginx `proxy_read_timeout`)
# so the backend fails cleanly instead of the proxy emitting a 504.
LESSON_PLAN_OPENAI_TIMEOUT=240
QUESTION_BANK_OPENAI_TIMEOUT=120

# Optional external AI offload (microservice-ready seam). Generation runs
# IN-PROCESS by default and that is the supported production path.
# The remote HTTP offload is used ONLY when BOTH of these are true:
#   1. AI_REMOTE_OFFLOAD_ENABLED=true, AND
#   2. a *_AI_SERVICE_URL below is set.
# Leaving AI_REMOTE_OFFLOAD_ENABLED=false (default) means a stale leftover URL
# (e.g. an old ngrok tunnel) is ignored instead of causing 502 Bad Gateway.
AI_REMOTE_OFFLOAD_ENABLED=false
LESSON_PLAN_AI_SERVICE_URL=""
# Timeout in seconds waiting for the remote AI service (generation can take minutes).
LESSON_PLAN_AI_SERVICE_TIMEOUT=300
QUESTION_BANK_AI_SERVICE_URL=""
QUESTION_BANK_AI_SERVICE_TIMEOUT=300

# Redis Configuration
REDIS_URL="redis://localhost:6379/0"

# Voice Call Integration — Twilio (Optional)
# Obtain from https://console.twilio.com (Account SID + Auth Token on dashboard)
# TWILIO_FROM_NUMBER must be a Twilio-purchased number in E.164 format (e.g. +14155551234)
TWILIO_ACCOUNT_SID="YOUR_TWILIO_ACCOUNT_SID"
TWILIO_AUTH_TOKEN="YOUR_TWILIO_AUTH_TOKEN"
TWILIO_FROM_NUMBER="+1XXXXXXXXXX"
# Optional tuning — defaults work in most cases
TWILIO_API_BASE_URL="https://api.twilio.com"
TWILIO_REQUEST_TIMEOUT_SECONDS=10
TWILIO_MAX_RETRIES=3
TWILIO_RETRY_BACKOFF_SECONDS=1
TWILIO_TTS_VOICE="alice"
TWILIO_TTS_LANGUAGE="en-IN"

# Fee-Reminder voice calls
# Set to "false" to send only push notifications on Wednesdays
FEE_REMINDER_VOICE_CALLS_ENABLED=true

# AWS S3 — Teacher private file library (optional; falls back to local disk)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_REGION="ap-south-1"
AWS_S3_BUCKET=""
AWS_S3_PRESIGN_TTL=900

# Fee-reminder automation scheduler.
# Default: false.  Enable on the ONE process/container that should own the
# scheduler loop.  If you run multiple Gunicorn workers in the same container
# (the default), enable it here — the tick-level leader election in
# fee_reminder_scheduler.py ensures only one worker actually executes each tick.
# On a multi-replica deployment (e.g. the EC2 Docker Compose stack with a
# separate worker container): set false on the web service and true only on
# the dedicated worker service.
FEE_REMINDER_SCHEDULER_ENABLED=true
