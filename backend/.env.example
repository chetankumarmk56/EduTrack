# EduTrack Backend Configuration

# General Application Settings
APP_NAME="EduTrack SaaS"
VERSION="1.0.0"
API_V1_STR="/api"
ENVIRONMENT="dev"  # dev, prod, test
PORT=8000

# Database configuration (PostgreSQL)
# For local dev: postgresql://luffy@localhost/school
DATABASE_URL="postgresql://user:password@host:port/dbname"

# ⚠️ SECURITY: SECRET_KEY is REQUIRED
# Generate a new secret key with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# MUST be at least 32 characters
SECRET_KEY="<GENERATE NEW KEY - Required for production>"

# JWT & Token Configuration
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security & CORS
FRONTEND_URL="http://localhost:5173"
COOKIE_DOMAIN=""  # Set to your domain in production (yourdomain.com)

# AI Configuration (Optional)
# Obtain from Google AI Studio (Gemini) — used by Lesson Plan feature
GOOGLE_API_KEY="YOUR_GOOGLE_AI_API_KEY"

# OpenAI (Question Bank Generator)
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4o-mini"

# Payment Integration (Optional)
RAZORPAY_KEY_ID="YOUR_RAZORPAY_KEY_ID"
RAZORPAY_KEY_SECRET="YOUR_RAZORPAY_KEY_SECRET"
RAZORPAY_WEBHOOK_SECRET="YOUR_RAZORPAY_WEBHOOK_SECRET"

# Redis Configuration
REDIS_URL="redis://localhost:6379/0"

# Phone/SMS Integration (Optional)
EXOTEL_SID="YOUR_EXOTEL_SID"
EXOTEL_API_KEY="YOUR_EXOTEL_API_KEY"
EXOTEL_API_TOKEN="YOUR_EXOTEL_API_TOKEN"
EXOTEL_FROM_NUMBER="YOUR_FROM_NUMBER"

# Azure Storage (Optional)
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_CONTAINER_NAME="announcements"

# AWS S3 — Teacher private file library (optional; falls back to local disk)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_REGION="ap-south-1"
AWS_S3_BUCKET=""
AWS_S3_PRESIGN_TTL=900
