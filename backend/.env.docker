# Docker Environment Configuration
# Use these variables to override local defaults when running in containers

# Database (Targets the 'db' service in docker-compose)
DATABASE_URL=postgresql://luffy:secret@db:5432/school

# Infrastructure (Targets the 'redis' service in docker-compose)
REDIS_URL=redis://redis:6379/0

# App Settings
ENVIRONMENT=prod
APP_NAME=EduTrack-Production
PORT=8000
